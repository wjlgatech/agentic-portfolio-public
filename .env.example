# ── Free-LLM survival chain (the copilot is "empowered by /free-llm") ────────────
# Set ANY ONE of these and the agentic copilot turns on. The route auto-selects the
# first available provider in this order: NVIDIA NIM → Groq → Gemini → OpenAI.
# All are OpenAI-compatible, so the same code path works for every provider.
#
# 1) NVIDIA NIM — free frontier models, ~40 req/min, key valid ~1 year.
#    Get a key (no card): https://build.nvidia.com/models  → register → copy nvapi-…
NVIDIA_API_KEY=
# NIM_MODEL=openai/gpt-oss-120b   # default; MUST support tool-calling (the agent uses tools)

# 2) Groq — fastest inference, ~30 req/min free.  https://console.groq.com
GROQ_API_KEY=
# GROQ_MODEL=openai/gpt-oss-120b   # default; tool-capable (llama-3.3 on Groq rejects tools)

# 3) Google Gemini — biggest free daily quota, no card.  https://aistudio.google.com
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# 4) OpenAI — paid fallback (only if you want it).
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ── Owner editing gate (optional but recommended for a deployed site) ────────────
# When set, only requests carrying this secret can APPLY layout/content edits via the
# agent; everyone else is view-only (they can ask + propose, not change). Unlock as
# owner by visiting your site with ?owner=<this value> once. Leave UNSET for local dev
# to stay un-gated (you're the owner on your own machine). Use a long random value.
PORTFOLIO_OWNER_TOKEN=

# ── Owner recovery email (Resend) — optional but recommended ──────────────────────
# Forgot the passphrase? The 🔒 badge (left blank) emails a 30-min magic link via
# /api/owner/recover; hosted /p/<slug> owners recover via /api/recover. Needs a free
# resend.com key. Without it, recovery degrades honestly (root → reset the env var;
# hosted → re-make with the same name + email).
# RESEND_API_KEY=
# RESEND_FROM=Agentic Portfolio <noreply@your-domain>
# PORTFOLIO_OWNER_EMAIL: where the ROOT recovery link is sent (defaults to profile.links.email).
# PORTFOLIO_OWNER_EMAIL=

# ── Compass scout (proactive "What's Next") ──────────────────────────────────────
# Lets the scheduled GitHub Action call POST /api/scout without the owner token. Set
# this to a long random value AND add the SAME value as a repo secret named
# SCOUT_SECRET (+ a repo variable PORTFOLIO_URL) so .github/workflows/compass-scout.yml
# can run on schedule. Leave UNSET to use the scout only via the owner "Scout now" button.
SCOUT_SECRET=

# ── Deepen pipeline ingest (inbound from super-u's flywheel) ──────────────────────
# Lets super-u's flywheel POST distilled knowledge+skills to /api/ingest-knowledge without
# the owner token (it's a WRITE surface — see docs/DEEPEN-PIPELINE.md). Set a long random
# value here AND pass it as the x-ingest-secret header from the orchestrator. Leave UNSET to
# accept ingests only with the owner token.
INGEST_SECRET=

# Optional: raises GitHub API rate limits for the live-evidence + collaborator search
# (Receipts + Compass). Unauthenticated works but is throttled. A classic token with
# PUBLIC repo read scope is plenty.
GITHUB_TOKEN=

# ── Durable storage (optional but recommended for the deployed site) ──────────────
# Without this, the serverless fs is read-only, so owner edits live in the browser and
# Network "joins" live per-instance. Attach a Vercel Postgres / Neon store and owner
# portfolio edits + Network registrations become DURABLE and SHARED across visitors.
# Vercel → Storage → Create (Postgres) injects POSTGRES_URL automatically; or paste a Neon
# connection string here. lib/storage.ts creates a tiny kv_store table on first use.
POSTGRES_URL=
# DATABASE_URL=        # accepted as a fallback if POSTGRES_URL is unset (raw Neon projects)

# ── Which site config to render ──────────────────────────────────────────────
# INSTANCE names a config in content/instances/ (default: portfolio = the personal site).
# An unknown value falls back to the portfolio (never errors).
# INSTANCE=portfolio
